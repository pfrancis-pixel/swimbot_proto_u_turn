 stack that does not tie up cpu_resources with its 1 hour (3600,000)</field></shadow></value><next><block type="quest_Note_6_quest_Show_String_For_Note_Small_Func" id="_ej-,}ZnNH/(.thyIaB`"><value name="textStrIn"><shadow type="text" id="mL.%?CQ9x*7.v+t@{}@G"><field name="TEXT">Also the 'if(false)' mini-stacks will be skipped by cpu, for further non-resource burdening</field></shadow></value><next><block type="controls_if" id="o|gZKp~^q|`SlQYb{uA8"><value name="IF0"><shadow type="logic_boolean" id="|~J.iMqD`AXV=YdEs.P!"><field name="BOOL">FALSE</field></shadow></value><statement name="DO0"><block type="quest_Note_6_quest_Show_String_For_Note_Big_Func" id="iF3qnhFgSIMu_y{K20*t"><value name="textStrIn"><shadow type="text" id="Jr2]M79//)?DowWe-}jG"><field name="TEXT">Staff: Very Important Notes</field></shadow></value><next><block type="controls_if" id="%(=lR#k@s(T$WM*y[~1J"><value name="IF0"><shadow type="logic_boolean" id="?;1JMKxy4~ioNWXZM{ba"><field name="BOOL">FALSE</field></shadow></value><statement name="DO0"><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="Ql!,e:xFr)$2.%X3!G`~"><value name="textStrIn"><shadow type="text" id="|dN[8x!B~L=B!^E{eYXC"><field name="TEXT">Levels 1, 2, 2.1</field></shadow></value><next><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="8C[h-tD+(.XP%J{R=u6c"><value name="textStrIn"><shadow type="text" id="v|Tq!/[:;M$Y_m/Bv(SX"><field name="TEXT">* Level 1: Hardcoded Static via Actual_Numbers for MotorPower%</field></shadow></value><next><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="os~9[1F`@BjWp-Fmg(G{"><value name="textStrIn"><shadow type="text" id="FwV:fiDcukU$gMbE4iF,"><field name="TEXT">* Level 2: Softcoded Dynamic via Variables/Constants for MotorPower% </field></shadow></value><next><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="*.g`XiU!U;wa~/VcvET7"><value name="textStrIn"><shadow type="text" id="{iPbU}%e9*Jq1tTy1yQ7"><field name="TEXT">* Level 2.1